+    $is_epoch = !is_array($value);
+
     $value = AphrontFormDateControlValue::newFromWild(
       $this->getViewer(),
       $value);
+
+    // A bare epoch value (e.g. supplied via Conduit) carries no "enabled" flag,
+    // so it would otherwise be treated as a disabled optional control and
+    // silently ignored. The web UI submits a {d, t, e} dictionary whose "e" key
+    // governs the enabled state, so only force-enable the epoch form.
+    if ($is_epoch) {
+      $value->setEnabled(true);
+    }
+
     return $value->setOptional(true);
   }
 
+  protected function newConduitParameterType() {
+    return new ConduitEpochParameterType();
+  }
